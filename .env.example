# =========================
# Embedding
# 維度必須和你 Gemini Embedding 輸出的 GUIDE_EMBEDDING_DIM 一樣
# =========================
GUIDE_EMBEDDING_PROVIDER=gemini
GUIDE_MODEL_PROVIDER=gemini
GUIDE_GEMINI_API_KEY=change_this_value
GUIDE_GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GUIDE_EMBEDDING_DIM=3072
GUIDE_GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite

# =========================
# Guide vector DB backend
# =========================
GUIDE_VECTOR_DB_BACKEND=qdrant

# =========================
# Qdrant Cloud
# 專屬導遊專用，避免和正式後端其他 Qdrant 混用
# =========================
GUIDE_QDRANT_URL=change_this_value
GUIDE_QDRANT_API_KEY=change_this_value
GUIDE_QDRANT_COLLECTION_NAME=change_this_value
GUIDE_QDRANT_TIMEOUT_SECONDS=180

# =========================
# Azure Blob Storage
# Azure Blob 仍然用來存原始 data 與圖片
# =========================
